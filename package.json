{
  "name": "adaptive-satellite-map",
  "displayName": "Adaptive Satellite Map",
  "description": "Satellite map with live aircraft model, exact camera footprint and telemetry-driven orientation.",
  "publisher": "alex-nurba-valya",
  "version": "0.3.0",
  "license": "MIT",
  "main": "./dist/extension.js",
  "keywords": [
    "foxglove",
    "map",
    "satellite",
    "uav",
    "aircraft",
    "mcap"
  ],
  "scripts": {
    "build": "foxglove-extension build",
    "foxglove:prepublish": "foxglove-extension build --mode production",
    "local-install": "foxglove-extension install",
    "package": "foxglove-extension package",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "maplibre-gl": "^5.6.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@foxglove/eslint-plugin": "2.0.0",
    "@foxglove/extension": "^2.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.180.0",
    "create-foxglove-extension": "1.3.2",
    "css-loader": "7.1.2",
    "eslint": "^9.39.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "style-loader": "4.0.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.48.0"
  }
}